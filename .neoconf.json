{
  "neodev": {
    "library": {
      "enabled": true,
      "plugins": true
    }
  },
  "neoconf": {
    "plugins": {
      "lua_ls": {
        "enabled": true
      }
    }
  }
  "lspconfig": {
    "lua_ls": {
      "Lua.diagnostics.globals": ["vim"],
      "Lua.workspace.checkThirdParty": false,
      "Lua.telemetry.enable": false
    }
  }
}
